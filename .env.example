# JDHP — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key (claude-sonnet-4-6 + claude-haiku-4-5)
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Gumroad API access token (for publishing and fetching sales)
# Get it from: https://app.gumroad.com/settings/advanced → "Generate access token"
GUMROAD_ACCESS_TOKEN=...

# Free exchange rate API key (INR → USD conversion for Gumroad pricing)
# Get it from: https://www.exchangerate-api.com (free tier, 1500 req/month)
EXCHANGERATE_API_KEY=...

# ── Optional overrides (defaults shown) ──────────────────────────────────────

# LOG_LEVEL=INFO
# DB_PATH=jdhp.db
# OUTPUT_DIR=output
